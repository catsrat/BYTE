{
  "rules": {
    "orders": {
      "$orderId": {
        ".read": true,
        ".write": "!data.exists() || (auth != null && auth.token.email != null)"
      },
      ".read": "auth != null && auth.token.email != null"
    },
    "settings": {
      ".read": true,
      ".write": "auth != null && auth.token.email != null"
    },
    "menu": {
      ".read": true,
      ".write": "auth != null && auth.token.email != null"
    },
    "discountCodes": {
      ".read": true,
      ".write": "auth != null && auth.token.email != null",
      "$code": {
        "usedBy": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid && !data.exists()"
          }
        }
      }
    }
  }
}
